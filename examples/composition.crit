// Function composition: chaining multiple function calls
fn double(n: int) -> int {
  return n * 2;
}

fn increment(n: int) -> int {
  return n + 1;
}

fn square(n: int) -> int {
  return n * n;
}

// Chain calls: square(increment(double(3))) = square(increment(6)) = square(7) = 49
let result: int = square(increment(double(3)));
print(result);

// Multiple independent calls
print(double(5));
print(increment(double(10)));
print(square(double(2)));
